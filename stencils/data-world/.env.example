# Copy this to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# Required: Postgres connection string
# Local Docker:  postgresql://postgres:world@localhost:5432/world
# Remote:        postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:world@localhost:5432/world

# Required for harness.py (Claude API)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used by harness.py
# Default: claude-opus-4-8
# WORLD_MODEL=claude-sonnet-4-6
